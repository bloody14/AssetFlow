generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  passwordHash String
  role         Role        @default(EMPLOYEE)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  status       UserStatus  @default(ACTIVE)

  sessions Session[]
  assets   Asset[]

  allocationsTo AssetAllocation[] @relation("AllocatedTo")
  allocationsBy AssetAllocation[] @relation("AllocatedBy")
  returnsBy     AssetAllocation[] @relation("ReturnedBy")
  auditLogs     AuditLog[]

  bookingsBooked   ResourceBooking[] @relation("BookedBy")
  bookingsApproved ResourceBooking[] @relation("ApprovedBy")

  maintenanceReported MaintenanceRequest[] @relation("ReportedBy")
  maintenanceAssigned MaintenanceRequest[] @relation("Technician")

  managedWarehouses     Warehouse[]        @relation("WarehouseManager")
  stockTransactions     StockTransaction[] @relation("StockTransactions")
  stockReservations     StockReservation[] @relation("StockReservations")
  cycleCounts           CycleCount[]       @relation("CycleCounts")
  purchaseRequests      PurchaseRequest[]  @relation("PRRequester")
  purchaseRequestApprovals PurchaseRequestApproval[] @relation("PRApprover")
  goodsReceiptsReceived GoodsReceipt[]           @relation("GoodsReceiver")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  version   Int       @default(1)
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Department {
  id                 String           @id @default(uuid())
  name               String           @unique
  parentDepartmentId String?
  parentDepartment   Department?      @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: Restrict)
  subDepartments     Department[]     @relation("DepartmentHierarchy")
  status             DepartmentStatus @default(ACTIVE)
  users              User[]
  assets             Asset[]
  purchaseRequests   PurchaseRequest[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  version   Int       @default(1)
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

model Session {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String @unique
  tokenFamily      String @default(uuid())

  status SessionStatus @default(ACTIVE)

  refreshCounter Int       @default(0)
  lastRefreshAt  DateTime?

  deviceId  String?
  userAgent String?
  ipAddress String?

  lastActiveAt DateTime @default(now())
  expiresAt    DateTime

  revokedAt    DateTime?
  revokeReason String?
  revokedBy    RevokedBy?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1)

  @@index([userId])
  @@index([tokenFamily])
  @@index([expiresAt])
  @@index([status])
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  COMPROMISED
  ARCHIVED
}

enum RevokedBy {
  USER
  ADMIN
  SYSTEM
  SECURITY_ENGINE
}

model LoginAttempt {
  id          String   @id @default(uuid())
  email       String
  ipAddress   String
  success     Boolean
  attemptTime DateTime @default(now())
}

model AssetCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  assets Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id           String  @id @default(uuid())
  assetTag     String  @unique
  serialNumber String? @unique
  name         String
  description  String?

  categoryId String
  category   AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  assignedUserId String?
  assignedUser   User?   @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  status AssetStatus @default(AVAILABLE)
  condition AssetCondition @default(EXCELLENT)
  qrIdentity String? @unique

  warrantyProvider String?
  warrantyStart DateTime?
  warrantyEnd DateTime?
  warrantyStatus String?

  allocations AssetAllocation[]
  bookings    ResourceBooking[]
  maintenance MaintenanceRequest[]
  timeline    AssetTimeline[]

  purchaseDate DateTime?
  purchaseCost Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  DAMAGED
  BROKEN
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  IN_MAINTENANCE
  RETIRED
  LOST
}

model AssetTimeline {
  id String @id @default(uuid())
  assetId String
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Restrict)
  eventType String
  actorId String
  actorType String
  notes String?
  timestamp DateTime @default(now())
  deletedAt DateTime?

  @@index([assetId])
}

model AssetAllocation {
  id      String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Restrict)

  allocatedToId String
  allocatedTo   User   @relation("AllocatedTo", fields: [allocatedToId], references: [id], onDelete: Restrict)

  allocatedById String
  allocatedBy   User   @relation("AllocatedBy", fields: [allocatedById], references: [id], onDelete: Restrict)

  allocatedAt DateTime @default(now())

  returnedAt   DateTime?
  returnedById String?
  returnedBy   User?     @relation("ReturnedBy", fields: [returnedById], references: [id], onDelete: Restrict)

  status AllocationStatus @default(ACTIVE)
  returnCondition AssetCondition?
  notes  String?
  deletedAt DateTime?
}

enum AllocationStatus {
  ACTIVE
  RETURNED
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  details    Json?
  createdAt  DateTime @default(now())
}

model ResourceBooking {
  id String @id @default(uuid())

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Restrict)

  bookedById String
  bookedBy   User   @relation("BookedBy", fields: [bookedById], references: [id], onDelete: Restrict)

  approvedById String?
  approvedBy   User?   @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: Restrict)

  startTime DateTime
  endTime   DateTime

  status BookingStatus @default(PENDING)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

model MaintenanceRequest {
  id String @id @default(uuid())

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Restrict)

  reportedById String
  reportedBy   User   @relation("ReportedBy", fields: [reportedById], references: [id], onDelete: Restrict)

  technicianId String?
  technician   User?   @relation("Technician", fields: [technicianId], references: [id], onDelete: Restrict)

  issue      String
  resolution String?
  cost       Float?
  attachments Json?

  status MaintenanceStatus @default(PENDING)

  scheduledStart DateTime?
  scheduledEnd   DateTime?
  completedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

enum MaintenanceStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ------------------------------------------------------
// Epic 3: Enterprise Inventory Platform
// ------------------------------------------------------

model Warehouse {
  id        String   @id @default(uuid())
  name      String   @unique
  location  String?
  managerId String?
  manager   User?    @relation("WarehouseManager", fields: [managerId], references: [id], onDelete: SetNull)
  status    WarehouseStatus @default(ACTIVE)

  stockLevels      StockLevel[]
  stockTransactions StockTransaction[]
  stockReservations StockReservation[]
  cycleCounts       CycleCount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

enum WarehouseStatus {
  ACTIVE
  INACTIVE
}

model InventoryCategory {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  isFixedAsset Boolean  @default(false)

  items InventoryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryItem {
  id             String   @id @default(uuid())
  sku            String   @unique
  name           String
  description    String?
  categoryId     String
  category       InventoryCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  unitOfMeasure  UnitOfMeasure     @default(PCS)
  reorderPoint   Int               @default(0)
  reorderQuantity Int              @default(0)

  stockLevels       StockLevel[]
  stockTransactions    StockTransaction[]
  stockReservations    StockReservation[]
  cycleCountItems      CycleCountItem[]
  supplierCatalogItems SupplierCatalogItem[]
  purchaseRequestItems PurchaseRequestItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  goodsReceiptItems    GoodsReceiptItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

enum UnitOfMeasure {
  PCS
  BOX
  PACK
  ROLL
  KG
  LITER
  METER
}

model StockLevel {
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  warehouseId     String
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  quantityAvailable Int @default(0)
  quantityReserved  Int @default(0)

  lastUpdated DateTime @default(now()) @updatedAt

  @@id([inventoryItemId, warehouseId])
}

model StockTransaction {
  id              String   @id @default(uuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  warehouseId     String
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  type            TransactionType
  quantity        Int
  referenceId     String?
  
  actorId         String
  actor           User   @relation("StockTransactions", fields: [actorId], references: [id], onDelete: Restrict)
  
  notes           String?
  createdAt       DateTime @default(now())
}

enum TransactionType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

model StockReservation {
  id              String   @id @default(uuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  warehouseId     String
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  quantity        Int
  status          ReservationStatus @default(PENDING)
  referenceId     String?
  notes           String?
  
  requestedById   String
  requestedBy     User   @relation("StockReservations", fields: [requestedById], references: [id], onDelete: Restrict)
  
  expiresAt       DateTime?
  fulfilledAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum ReservationStatus {
  PENDING
  FULFILLED
  CANCELLED
  EXPIRED
}

model CycleCount {
  id              String   @id @default(uuid())
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  status          CycleCountStatus @default(PENDING)
  notes           String?
  
  requestedById   String
  requestedBy     User   @relation("CycleCounts", fields: [requestedById], references: [id], onDelete: Restrict)
  
  items           CycleCountItem[]
  
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CycleCountItem {
  id              String   @id @default(uuid())
  cycleCountId    String
  cycleCount      CycleCount @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  
  expectedQuantity Int
  countedQuantity  Int?
  variance         Int?
  
  adjustmentReason AdjustmentReason?
  notes            String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([cycleCountId, inventoryItemId])
}

enum CycleCountStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AdjustmentReason {
  SHRINKAGE
  DAMAGE
  OBSOLESCENCE
  FOUND
  OTHER
}

// ------------------------------------------------------
// Epic 4: Procurement Platform
// ------------------------------------------------------

model Supplier {
  id              String   @id @default(uuid())
  name            String   @unique
  code            String?  @unique
  taxId           String?
  website         String?
  status          SupplierStatus @default(PENDING_APPROVAL)
  
  rating          Float?
  leadTimeDays    Int?
  
  contacts        SupplierContact[]
  catalogItems    SupplierCatalogItem[]
  purchaseOrders  PurchaseOrder[]
  metrics         SupplierMetrics?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
}

enum SupplierStatus {
  ACTIVE
  PENDING_APPROVAL
  INACTIVE
  SUSPENDED
  BLACKLISTED
}

model SupplierContact {
  id          String   @id @default(uuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  firstName   String
  lastName    String
  email       String
  phone       String?
  isPrimary   Boolean  @default(false)
  role        String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([supplierId, email])
}

model SupplierCatalogItem {
  id              String   @id @default(uuid())
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  
  supplierSku     String
  price           Float
  currency        String   @default("USD")
  minimumOrderQty Int      @default(1)
  leadTimeDays    Int?
  
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([supplierId, inventoryItemId])
  @@unique([supplierId, supplierSku])
}

// ------------------------------------------------------
// Epic 4 Phase 4.2: Purchase Requests
// ------------------------------------------------------

enum PurchaseRequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model PurchaseRequest {
  id              String   @id @default(uuid())
  requesterId     String
  requester       User     @relation("PRRequester", fields: [requesterId], references: [id])
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id])
  
  justification   String
  priority        PurchaseRequestPriority @default(MEDIUM)
  status          ApprovalStatus @default(PENDING)
  
  items           PurchaseRequestItem[]
  approvals       PurchaseRequestApproval[]
  purchaseOrders  PurchaseOrder[]
  timelineEvents  ProcurementTimeline[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
}

model PurchaseRequestItem {
  id                String   @id @default(uuid())
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  
  inventoryItemId   String
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  
  quantity          Int
  estimatedPrice    Float?
  currency          String   @default("USD")
  purchaseOrderItems PurchaseOrderItem[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PurchaseRequestApproval {
  id                String   @id @default(uuid())
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  
  approverId        String
  approver          User     @relation("PRApprover", fields: [approverId], references: [id])
  
  status            ApprovalStatus
  comments          String?
  step              Int      @default(1)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ------------------------------------------------------
// Epic 4 Phase 4.3: Purchase Orders
// ------------------------------------------------------

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  FULFILLED
  CANCELLED
}

model PurchaseOrder {
  id                String   @id @default(uuid())
  orderNumber       String   @unique
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Restrict)
  
  supplierId        String
  supplier          Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  
  status            PurchaseOrderStatus @default(DRAFT)
  expectedDelivery  DateTime?
  
  items             PurchaseOrderItem[]
  goodsReceipts     GoodsReceipt[]
  timelineEvents    ProcurementTimeline[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
}

model PurchaseOrderItem {
  id                  String   @id @default(uuid())
  purchaseOrderId     String
  purchaseOrder       PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  purchaseRequestItemId String?
  purchaseRequestItem   PurchaseRequestItem? @relation(fields: [purchaseRequestItemId], references: [id], onDelete: SetNull)
  
  inventoryItemId     String
  inventoryItem       InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  
  quantityOrdered     Int
  quantityReceived    Int      @default(0)
  unitPrice           Float
  currency            String   @default("USD")
  
  goodsReceiptItems   GoodsReceiptItem[]
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ------------------------------------------------------
// Epic 4 Phase 4.4: Goods Receipt
// ------------------------------------------------------

model GoodsReceipt {
  id                String   @id @default(uuid())
  receiptNumber     String   @unique
  purchaseOrderId   String
  purchaseOrder     PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  
  receivedById      String
  receivedBy        User     @relation("GoodsReceiver", fields: [receivedById], references: [id])
  
  items             GoodsReceiptItem[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
}

model GoodsReceiptItem {
  id                  String   @id @default(uuid())
  goodsReceiptId      String
  goodsReceipt        GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  
  purchaseOrderItemId String
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Restrict)
  
  inventoryItemId     String
  inventoryItem       InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  
  quantityReceived    Int
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ------------------------------------------------------
// Epic 4 Phase 4.5: Procurement Analytics Foundation
// ------------------------------------------------------

model ProcurementTimeline {
  id                String   @id @default(uuid())
  
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  purchaseRequestId String?
  purchaseRequest   PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  
  eventType         String
  eventPayload      Json?
  
  createdAt         DateTime @default(now())
}

model SupplierMetrics {
  id                   String   @id @default(uuid())
  supplierId           String   @unique
  supplier             Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  averageLeadTimeDays  Float    @default(0)
  qualityScore         Float    @default(0)
  totalOrdersFulfilled Int      @default(0)
  
  calculatedAt         DateTime @default(now())
  calculationVersion   String   @default("v1")
  
  updatedAt            DateTime @updatedAt
}
